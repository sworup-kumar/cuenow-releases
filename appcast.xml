        <item>
            <title>1.0.52</title>
            <pubDate>Wed, 27 May 2026 23:21:01 +0530</pubDate>
            <sparkle:version>52</sparkle:version>
            <sparkle:shortVersionString>1.0.52</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <sparkle:hardwareRequirements>arm64</sparkle:hardwareRequirements>
            <description sparkle:format="markdown"><![CDATA[- Fixed note persistence when reopening CueNow after quitting the app.
- Fixed storage path handling so notes in `Application Support/CueNow` are loaded correctly instead of being replaced by a blank note.
- Added regression coverage for note storage paths containing spaces.
]]></description>

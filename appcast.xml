        <item>
            <title>1.0.5</title>
            <pubDate>Wed, 27 May 2026 18:50:20 +0530</pubDate>
            <sparkle:version>6</sparkle:version>
            <sparkle:shortVersionString>1.0.5</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <sparkle:hardwareRequirements>arm64</sparkle:hardwareRequirements>
            <description sparkle:format="markdown"><![CDATA[- Notes you create, edit, or delete are now flushed to disk on every clean quit, so nothing is lost if you quit shortly after a change.
- Notes that were open on screen when you quit now reopen at their saved positions when you relaunch — notes you had explicitly closed stay minimized in the menu-bar dropdown.
]]></description>
            <enclosure url="https://github.com/sworup-kumar/cuenow-releases/releases/download/v1.0.5/CueNow-1.0.5.dmg" length="2799853" type="application/octet-stream" sparkle:edSignature="PceSd7OgAkL/NfR8Wxk0EtFR2Z0yQ6OEUMt+ZQgKAYKMEW9u/uokV8bNmn+y+25HDbvGhSrv96+ICNpQCG4UAQ=="/>

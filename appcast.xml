        <item>
            <title>1.3.2</title>
            <pubDate>Thu, 25 Jun 2026 11:49:12 +0530</pubDate>
            <sparkle:version>63</sparkle:version>
            <sparkle:shortVersionString>1.3.2</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <sparkle:hardwareRequirements>arm64</sparkle:hardwareRequirements>
            <description sparkle:format="markdown"><![CDATA[- Fixed two thin lines that appeared above and below a line when bold, italic, or underline formatting covered the full width of a note.
- Numbered lists now renumber automatically when you add or remove an item in the middle of the list.
- Starting a new list right after leaving another one no longer merges it into the list above.
- The Settings window now moves only when you drag its title bar, and it no longer springs back to its original position.
]]></description>
            <enclosure url="https://github.com/sworup-kumar/cuenow-releases/releases/download/v1.3.2/CueNow-1.3.2.dmg" length="2906330" type="application/octet-stream" sparkle:edSignature="Tr7Y6S5gQa8aXiZXv3ZozR516wmAuPSC3hIkf0opVclJU/jJaz3DxJPiyUJc60qVa5MH1bfVluu78TZcSeoODQ=="/>
        </item>
        <item>
            <title>1.3.1</title>
            <pubDate>Sat, 20 Jun 2026 12:42:34 +0530</pubDate>
            <sparkle:version>62</sparkle:version>
            <sparkle:shortVersionString>1.3.1</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <sparkle:hardwareRequirements>arm64</sparkle:hardwareRequirements>
            <description sparkle:format="markdown"><![CDATA[- Refreshed the About and software update windows with a cleaner, simpler look.
- The "All Notes" menu now shows a small dot for every note — filled when the note is open on screen, and an outline when it's closed.
- Note titles in the menu now use the full width instead of cutting off early.
- The delete button in the menu bar notes list stays neatly in place when you hover.
]]></description>
